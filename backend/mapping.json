{
  "mapping_definition": {
    "name": "GRID-Raw-Equivalence-Map",
    "version": "1.2",
    "description": "Precise Path Definition based on BSI-CSAF and ENISA-EUVD Raw Data"
  },
  "join_logic": {
    "primary_key": {
      "csaf_path": "document.vulnerabilities.cve",
      "euvd_path": "cve_ids",
      "match_type": "array_lookup",
      "note": "CSAF uses an array under document.vulnerabilities; EUVD uses the cve_ids array created by the ingester."
    }
  },
  "equivalent_fields": {
    "cvss_base_score": {
      "csaf": "document.vulnerabilities.scores.cvss_v3.base_score",
      "euvd": "baseScore"
    },
    "cvss_vector": {
      "csaf": "document.vulnerabilities.scores.cvss_v3.vector_string",
      "euvd": "baseScoreVector"
    },
    "summary_text": {
      "csaf": "document.notes",
      "csaf_filter": "category == 'summary'",
      "euvd": "description"
    },
    "publication_date": {
      "csaf": "document.tracking.initial_release_date",
      "euvd": "datePublished"
    },
    "modification_date": {
      "csaf": "document.tracking.current_release_date",
      "euvd": "dateUpdated"
    },
    "source_identifier": {
      "csaf": "document.tracking.id",
      "euvd": "id"
    },
    "exploitation_status": {
      "csaf": "document.vulnerabilities.threats.details",
      "euvd": "exploited_since"
    }
  }
}